# .env
# Naming images
COMPOSE_PROJECT_NAME=

# Discord Bot Token
DISCORD_BOT_TOKEN=

# Stripe API Keys
TEST_STRIPE_SECRET_KEY=
STRIPE_SECRET_KEY=
STRIPE_RESTRICTED_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=
STRIPE_PAYMENT_WEBHOOK_SECRET=
TEST_STRIPE_WEBHOOK_SECRET=

# Database URL
# This repo only ever connects to the VerifyMe verification database.
# It must never be given credentials for any other database (DJ, VRCVerify,
# etc.) -- those products no longer bill through Stripe/this repo.
DATABASE_URL_VERIFICATION=

# RabbitMQ Configuration
RABBITMQ_HOST=
RABBITMQ_PORT=
RABBITMQ_USERNAME=
RABBITMQ_PASSWORD=
RABBITMQ_VHOST=
RABBITMQ_QUEUE_NAME=

# Logging Level: DEBUG, INFO, WARNING, ERROR, CRITICAL
LOG_LEVEL=INFO

# Encryption for dob
DOB_KEY=

# Optional: instruction panel runtime refresh (touch the trigger file inside
# the bot container to re-edit all instruction panels without a restart)
# INSTRUCTIONS_TRIGGER_PATH=/tmp/update_instructions.trigger
# INSTRUCTIONS_TRIGGER_POLL=5

# Discord storefront SKUs (Premium Apps). Fill in the SKU snowflake IDs from
# the Developer Portal (Monetization > Manage SKUs). Unset tiers/packs are
# simply not offered; with none set, /get_subscription falls back to the
# legacy website link. Guild-subscription tiers (tier_N = internal tier):
# DISCORD_SKU_TIER_0=
# DISCORD_SKU_TIER_1=
# DISCORD_SKU_TIER_2=
# DISCORD_SKU_TIER_3=
# DISCORD_SKU_TIER_4=
# DISCORD_SKU_TIER_5=
# DISCORD_SKU_TIER_6=
# Consumable extra-token packs:
# DISCORD_SKU_TOKENS_10=
# DISCORD_SKU_TOKENS_25=
# DISCORD_SKU_TOKENS_50=
# DISCORD_SKU_TOKENS_100=
# Tuning (defaults shown):
# PURCHASE_CONTEXT_TTL_SECONDS=3600
# ENTITLEMENT_GRACE_DAYS=3